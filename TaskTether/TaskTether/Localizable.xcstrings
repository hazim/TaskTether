{
  "sourceLanguage" : "en",
  "strings" : {
    "app.name" : {
      "comment" : "The application name, shown in the menu bar popover header.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TaskTether"
          }
        }
      }
    },
    "connect.button.idle" : {
      "comment" : "Label on the Google sign-in button when idle.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Connect Google Account"
          }
        }
      }
    },
    "connect.button.loading" : {
      "comment" : "Label on the Google sign-in button while authentication is in progress.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Connecting..."
          }
        }
      }
    },
    "connect.description" : {
      "comment" : "Short description shown on the connect screen below the app name.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sync Apple Reminders with Google Tasks seamlessly."
          }
        }
      }
    },
    "error.auth.token" : {
      "comment" : "Error shown when the OAuth token exchange with Google fails.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Token exchange failed"
          }
        }
      }
    },
    "error.auth.url" : {
      "comment" : "Error shown when the Google OAuth URL cannot be constructed.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Could not build auth URL"
          }
        }
      }
    },
    "error.credentials" : {
      "comment" : "Error shown when GoogleCredentials.json cannot be loaded from the bundle.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Could not load credentials"
          }
        }
      }
    },
    "error.reminders.createlist" : {
      "comment" : "Error shown when the TaskTether list cannot be created in Reminders. %@ is replaced with the system error description.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Could not create TaskTether list: %@"
          }
        }
      }
    },
    "error.reminders.denied.v12" : {
      "comment" : "Error shown on macOS 12–13 (Monterey/Ventura) when Reminders access is denied. 'System Preferences' is the correct name on those versions.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reminders access denied. Please enable in System Preferences → Security & Privacy → Reminders."
          }
        }
      }
    },
    "error.reminders.denied.v14" : {
      "comment" : "Error shown on macOS 14+ (Sonoma and later) when Reminders access is denied. 'System Settings' is the correct name from macOS 13 onwards.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reminders access denied. Please enable in System Settings → Privacy → Reminders."
          }
        }
      }
    },
    "error.tasks.createlist" : {
      "comment" : "Error shown when the TaskTether list cannot be created in Google Tasks.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Could not create TaskTether list"
          }
        }
      }
    },
    "error.tasks.fetchlists" : {
      "comment" : "Error shown when the Google Tasks list fetch request fails or returns unexpected data.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Could not fetch task lists"
          }
        }
      }
    },
    "error.tasks.notoken" : {
      "comment" : "Error shown internally when Google Tasks setup is attempted but no access token is available.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No access token"
          }
        }
      }
    },
